# ─── AI Provider ──────────────────────────────────────────────────────────────
# Required: your Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI key if using --ai-provider openai
OPENAI_API_KEY=

# ─── CVE / NVD ────────────────────────────────────────────────────────────────
# Optional but recommended: avoids NVD rate-limiting (register at https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=

# ─── Execution Limits ─────────────────────────────────────────────────────────
MAX_AGENT_LOOPS=15
DEFAULT_TIMEOUT=180

# ─── Database ─────────────────────────────────────────────────────────────────
# Relative to working directory; set absolute path to persist across runs
DB_PATH=.hcli_state.db
