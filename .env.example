# ─── AI Provider (AUTO-DETECTED — no AI_PROVIDER needed) ──────────────────────
#
# GhillieSuite-EX.sec detects your AI provider automatically based on the key prefix:
#   sk-...   → OpenAI  (gpt-4o-mini)
#   AIza...  → Google Gemini  (gemini-2.5-pro)
#
# If BOTH are set, OpenAI takes priority.
# You only need to set ONE of these.

# Option A — Google Gemini (free tier available)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Option B — OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# -- Optional AI Fallback (used only if primary refuses/blocks)
# Choose ONE provider and set its key/model below.
AI_FALLBACK_PROVIDER=ollama  # options: ollama | anthropic | xai | openai | gemini | openai_compatible
AI_FALLBACK_API_KEY=         # used by openai/openai_compatible/xai/anthropic when required
AI_FALLBACK_BASE_URL=        # e.g. https://api.x.ai/v1 for Grok, or https://api.openai.com/v1
AI_FALLBACK_MODEL=           # e.g. grok-2-1212, claude-3-5-sonnet-20240620, gpt-4o-mini

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# xAI (Grok)
XAI_API_KEY=
XAI_MODEL=grok-2-1212

# ─── CVE / NVD ────────────────────────────────────────────────────────────────
# Optional but recommended — avoids NVD rate-limiting
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ─── Execution Limits ─────────────────────────────────────────────────────────
MAX_AGENT_LOOPS=15
DEFAULT_TIMEOUT=180
NUCLEI_TIMEOUT=600
FAST_NUCLEI=0

# â”€â”€â”€ JS Deep Inspection Tuning â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
JS_MAX_WORKERS=8
JS_MAX_FILES=300
JS_LLM_CONCURRENCY=2
JS_SNIPPET_MAX_LEN=500
JS_HTTP_TIMEOUT=10
JS_LLM_TIMEOUT=8

# ─── Database ─────────────────────────────────────────────────────────────────
# Set to an absolute path to persist DB across runs / working directories
DB_PATH=~/GhillieSuite-EX/ghilliesuite_state.db

# Katana Deep Tuning
KATANA_MAX_TARGETS=20
KATANA_RATE_LIMIT=30
KATANA_DEPTH=6
KATANA_RECRAWL_INTERVAL=3
KATANA_MAX_ENDPOINTS_PER_TARGET=4000

# Optional Recon Add-ons (OFF by default)
RECON_ENABLE_DNSX=0
RECON_ENABLE_NAABU=0
RECON_ENABLE_SUBZY=0

