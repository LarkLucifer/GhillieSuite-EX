# в”Ђв”Ђв”Ђ AI Provider (AUTO-DETECTED вЂ” no AI_PROVIDER needed) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
#
# hcli.sec detects your AI provider automatically based on the key prefix:
#   sk-...   в†’ OpenAI  (gpt-4o-mini)
#   AIza...  в†’ Google Gemini  (gemini-2.5-pro)
#
# If BOTH are set, OpenAI takes priority.
# You only need to set ONE of these.

# Option A вЂ” Google Gemini (free tier available)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Option B вЂ” OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# -- Optional AI Fallback (used only if primary refuses/blocks)
# Choose ONE provider and set its key/model below.
AI_FALLBACK_PROVIDER=ollama  # options: ollama | anthropic | xai | openai | gemini | openai_compatible
AI_FALLBACK_API_KEY=         # used by openai/openai_compatible/xai/anthropic when required
AI_FALLBACK_BASE_URL=        # e.g. https://api.x.ai/v1 for Grok, or https://api.openai.com/v1
AI_FALLBACK_MODEL=           # e.g. grok-2-1212, claude-3-5-sonnet-20240620, gpt-4o-mini

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# xAI (Grok)
XAI_API_KEY=
XAI_MODEL=grok-2-1212

# в”Ђв”Ђв”Ђ CVE / NVD в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Optional but recommended вЂ” avoids NVD rate-limiting
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# в”Ђв”Ђв”Ђ Execution Limits в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MAX_AGENT_LOOPS=15
DEFAULT_TIMEOUT=180

# ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ JS Deep Inspection Tuning ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
JS_MAX_WORKERS=8
JS_LLM_CONCURRENCY=2
JS_SNIPPET_MAX_LEN=500
JS_HTTP_TIMEOUT=10
JS_LLM_TIMEOUT=8

# в”Ђв”Ђв”Ђ Database в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Set to an absolute path to persist DB across runs / working directories
DB_PATH=.hcli_state.db
